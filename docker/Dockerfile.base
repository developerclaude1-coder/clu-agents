FROM python:3.12-slim

# System deps — minimal
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl ca-certificates && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /agent

# Python deps for all agents
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Agent runner (shared entrypoint)
COPY agent-runner.py .

# Agent identity + memory (mounted as volumes at runtime)
# /agent/CLAUDE.md      — agent identity (read-only bind mount from git)
# /agent/memory/        — persistent agent memory (named volume)
# /agent/tasks/         — shared task queue (bind mount from ~/tools/clu-tasks/)

ENV PYTHONUNBUFFERED=1
ENV AGENT_NAME=""
ENV OLLAMA_HOST="http://100.90.97.7:11434"
ENV OLLAMA_FAST_MODEL="llama3.1:8b"
ENV OLLAMA_CODE_MODEL="qwen2.5-coder:14b"
ENV OLLAMA_THINK_MODEL="deepseek-r1:14b"
ENV GEMINI_MODEL="gemini-2.5-flash"

ENTRYPOINT ["python3", "agent-runner.py"]
